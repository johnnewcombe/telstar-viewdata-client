<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TelstarClient.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="TelstarClient.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Viewdata Client"
        Height="900"
        Width="1200"
        MinHeight="480"
        MinWidth="600"
        Background="Black"
        KeyDown="Window_KeyDown"
        TextInput="Window_TextInput"
        >
    <!--
      Window can only have ONE direct child (its Content) - this Grid is
      that single child, and holds both displays side by side in two
      columns for comparison. Remove this wrapper (and one of the two
      children) once you're happy with the bitmap version and want to
      drop the old UniformGrid renderer.
    -->

        <!--UniformGrid Grid.Column="0" Margin="10,10,10,10" Name="Display" Columns="40" Rows="25" Background="Black" /-->
        <!--
          RenderOptions.BitmapInterpolationMode="None" gives crisp, blocky,
          nearest-neighbour scaling as the window resizes - the authentic
          "CRT emulator" look discussed earlier. Switch to "HighQuality"
          for smooth/anti-aliased scaling instead if you'd rather compare
          that look too.
        -->
        <Image
            Name="BitmapDisplay"
            Stretch="Fill"
            RenderOptions.BitmapInterpolationMode="None"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />
</Window>
